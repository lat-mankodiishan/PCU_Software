{
    "version": "0.2.0",
    "configurations": [
        {
            // Primary debug config: flash + run + symbols + Live Watch + FreeRTOS-aware threads.
            // Uses ST's stlinkgdbtarget extension (STM32Cube IDE for VS Code).
            "name": "STM32Cube: ST-Link GDB Server (Launch)",
            "type": "stlinkgdbtarget",
            "request": "launch",
            "cwd": "${workspaceFolder}",

            // Build the active CMake target before launching. Comment out to skip.
            "preBuild": "${command:st-stm32-ide-debug-launch.build}",

            // Reset the PCU when Stop Debug is clicked — guarantees the
            // experiment_task / motor / engine don't keep running after the
            // debugger detaches. See .vscode/tasks.json "reset-stm32".
            "postDebugTask": "reset-stm32",

            // ELF for both flashing and symbols.
            "imagesAndSymbols": [
                {
                    "imageFileName":  "${workspaceFolder}/build/Debug/Software_Hybrid.elf",
                    "symbolFileName": "${workspaceFolder}/build/Debug/Software_Hybrid.elf"
                }
            ],

            "runEntry": "main",

            // Device + register view (SVD lets you inspect peripherals in the side panel).
            "deviceName": "STM32F405RG",
            "deviceCore": "Cortex-M4",
            "svdPath": "${env:LOCALAPPDATA}/stm32cube/packs/STMicroelectronics/stm32f4xx_dfp/1.2.0/SVD/STM32F405.svd",

            // GDB client behaviour.
            "gdbAsync": true,
            "gdbNonStop": false,
            "openGdbConsole": false,
            "verbose": false,
            "logFile": "${workspaceFolder}/build/gdbClient_log.txt",

            // CPU fault traps. Halts on div-by-zero and on any escalated exception.
            "faultDivByZero": true,
            "faultUnalignedAccess": false,
            "faultHaltOnException": true,

            // Non-intrusive memory poller for the STM32 Live Watch panel.
            "liveWatch": {
                "enabled": true,
                "samplesPerSecond": "4"
            },

            // ST-Link GDB Server settings
            "serverHost": "localhost",
            "serverPort": "61234",
            "serverInterface": "SWD",
            "serverInterfaceFrequency": "Auto",
            "serverVerify": true,
            "serverIncrementalFlashing": false,
            "serverShared": false,
            "serverHaltAllCores": false,
            "serverLogFile": "${workspaceFolder}/build/stlinkgdbserver_log.txt",
            "automaticallyKillServer": true,

            // Note: If you keep this, ignore the yellow validation line. 
            // Alternatively, manage your probe via the "STM32CUBE DEVICES AND BOARDS" sidebar panel.
            "serverArgs": [
                "--serial-number", "B55B5A1A000000008729F501"
            ],

            // FreeRTOS thread-aware debug via ST's RTOS proxy.
            "serverRtos": {
                "enabled": false,
                "driver": "freertos",
                "driverPort": "ARM_CM4F",
                "port": "60000"
            },

            // Semihosting off by default (your firmware uses ITM/UART, not semihosting printf).
            "serverSemihosting": {
                "enabled": false,
                "mode": "console",
                "port": "61260"
            }
        },

        {
            // Attach to a target that's already powered and flashed. No build, no flash.
            "name": "STM32Cube: ST-Link GDB Server (Attach)",
            "type": "stlinkgdbtarget",
            "request": "attach",
            "cwd": "${workspaceFolder}",
            "postDebugTask": "reset-stm32",
            "imagesAndSymbols": [
                { "symbolFileName": "${workspaceFolder}/build/Debug/Software_Hybrid.elf" }
            ],
            "deviceName": "STM32F405RG",
            "deviceCore": "Cortex-M4",
            "svdPath": "${env:LOCALAPPDATA}/stm32cube/packs/STMicroelectronics/stm32f4xx_dfp/1.2.0/SVD/STM32F405.svd",
            "gdbAsync": true,
            "gdbNonStop": false,
            "liveWatch": {
                "enabled": true,
                "samplesPerSecond": "4"
            },
            "serverHost": "localhost",
            "serverPort": "61234",
            
            "serverArgs": [
                "--serial-number", "B55B5A1A000000008729F501"
            ],

            "serverRtos": {
                "enabled": false,
                "driver": "freertos",
                "driverPort": "ARM_CM4F",
                "port": "60000"
            }
        },

        {
            // Kept around for SWO/ITM printf streaming, which stlinkgdbtarget doesn't expose.
            "name": "Cortex-Debug: ST-Link with SWO/ITM",
            "type": "cortex-debug",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/Debug/Software_Hybrid.elf",
            "servertype": "stlink",
            "device": "STM32F405RG",
            "interface": "swd",

            // FIX: This is the correct property name for Cortex-Debug schema validation
            "serialNumber": "B55B5A1A000000008729F501",

            "runToEntryPoint": "main",
            "showDevDebugOutput": "none",
            "svdFile": "${env:LOCALAPPDATA}/stm32cube/packs/STMicroelectronics/stm32f4xx_dfp/1.2.0/SVD/STM32F405.svd",
            "swoConfig": {
                "enabled": true,
                "cpuFrequency": 60000000,
                "swoFrequency": 2000000,
                "source": "probe",
                "decoders": [
                    { "type": "console", "label": "ITM", "port": 0 }
                ]
            }
        }
    ]
}