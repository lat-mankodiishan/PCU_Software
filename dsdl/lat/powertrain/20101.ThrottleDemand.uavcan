#
# Throttle demand + flight phase — broadcast FC -> PCU at ~50 Hz.
# Mirrored on PCU side into vesc_mode_t for control_law.
#
# DTID 20101 (LAT vendor range, DroneCAN private namespace).
#

# Flight phase enum — must match vesc_mode_t in vesc_proto.h
uint4 IDLE    = 0
uint4 TAKEOFF = 1
uint4 CLIMB   = 2
uint4 CRUISE  = 3
uint4 LAND    = 4
uint4 FAULT   = 5

uint4 flight_phase
void12                      # padding to byte boundary

float16 throttle_pct        # 0..100 [%]
